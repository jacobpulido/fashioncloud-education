generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core schemas
model instituciones {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String
  slug      String   @unique
  logo_url  String?
  config    Json     @default("{}")
  activa    Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @updatedAt @db.Timestamptz()
}

model usuarios {
  id              String   @id @default(uuid()) @db.Uuid
  institucion_id  String   @db.Uuid
  email           String
  password_hash   String
  nombre          String
  apellidos       String   @default("")
  avatar_url      String?
  telefono        String?
  mfa_habilitado  Boolean  @default(false)
  mfa_secret      String?
  estado          String   @default("activo")
  ultimo_acceso   DateTime? @db.Timestamptz()
  created_at      DateTime @default(now()) @db.Timestamptz()
  updated_at      DateTime @updatedAt @db.Timestamptz()
  deleted_at      DateTime? @db.Timestamptz()


  @@unique([institucion_id, email])
  @@index([institucion_id])
}

model roles {
  id          String   @id @default(uuid()) @db.Uuid
  clave       String   @unique
  nombre      String
  descripcion String?

}

model permisos {
  id          String   @id @default(uuid()) @db.Uuid
  clave       String   @unique
  nombre      String

}

model rol_permisos {
  rol_id     String @db.Uuid
  permiso_id String @db.Uuid


  @@id([rol_id, permiso_id])
}

model usuario_roles {
  usuario_id String @db.Uuid
  rol_id     String @db.Uuid


  @@id([usuario_id, rol_id])
}

model sesiones {
  id           String   @id @default(uuid()) @db.Uuid
  usuario_id   String   @db.Uuid
  refresh_hash String
  user_agent   String?
  ip           String?  @db.Text
  expira_en    DateTime @db.Timestamptz()
  revocada_en  DateTime? @db.Timestamptz()
  created_at   DateTime @default(now()) @db.Timestamptz()

}

model periodos {
  id              String   @id @default(uuid()) @db.Uuid
  institucion_id  String   @db.Uuid
  nombre          String
  fecha_inicio    DateTime @db.Date
  fecha_fin       DateTime @db.Date
  estado          String   @default("activo")
  created_at      DateTime @default(now()) @db.Timestamptz()


  @@index([institucion_id])
}

model grupos {
  id              String   @id @default(uuid()) @db.Uuid
  institucion_id  String   @db.Uuid
  nombre          String
  nivel           String?
  created_at      DateTime @default(now()) @db.Timestamptz()


  @@unique([institucion_id, nombre])
  @@index([institucion_id])
}

model grupo_alumnos {
  grupo_id  String @db.Uuid
  alumno_id String @db.Uuid


  @@id([grupo_id, alumno_id])
}

model materias {
  id                String   @id @default(uuid()) @db.Uuid
  institucion_id    String   @db.Uuid
  nombre            String
  periodo_id        String   @db.Uuid
  grupo_id          String   @db.Uuid
  docente_id        String   @db.Uuid
  color             String?
  ponderaciones_ok  Boolean  @default(false)
  created_at        DateTime @default(now()) @db.Timestamptz()
  updated_at        DateTime @updatedAt @db.Timestamptz()


  @@index([institucion_id])
  @@index([docente_id])
  @@index([periodo_id])
}

model ponderaciones_materia {
  materia_id String  @db.Uuid
  tipo       String
  peso       Decimal @db.Decimal(5, 2)


  @@id([materia_id, tipo])
}

model inscripciones {
  id          String   @id @default(uuid()) @db.Uuid
  materia_id  String   @db.Uuid
  alumno_id   String   @db.Uuid
  estado      String   @default("activa")
  created_at  DateTime @default(now()) @db.Timestamptz()


  @@unique([materia_id, alumno_id])
  @@index([materia_id])
  @@index([alumno_id])
}

model historial_academico {
  id                String   @id @default(uuid()) @db.Uuid
  institucion_id    String   @db.Uuid
  alumno_id         String   @db.Uuid
  materia_id        String   @db.Uuid
  periodo_id        String   @db.Uuid
  calificacion_final Decimal @db.Decimal(5, 2)
  desglose          Json     @default("{}")
  cerrado_por       String?  @db.Uuid
  cerrado_en        DateTime @default(now()) @db.Timestamptz()


  @@unique([alumno_id, materia_id, periodo_id])
  @@index([alumno_id])
}

model auditoria {
  id              Int   @id @default(autoincrement())
  institucion_id  String?  @db.Uuid
  usuario_id      String?  @db.Uuid
  accion          String
  entidad         String?
  entidad_id      String?  @db.Uuid
  resultado       String   @default("ok")
  ip              String?  @db.Text
  user_agent      String?
  metadata        Json     @default("{}")
  created_at      DateTime @default(now()) @db.Timestamptz()

  @@index([institucion_id, created_at])
  @@index([accion, created_at])
}

// Academy module models
model actividades {
  id              String   @id @default(uuid()) @db.Uuid
  institucion_id  String   @db.Uuid
  materia_id      String   @db.Uuid
  tipo            String
  titulo          String
  descripcion     String   @default("")
  fecha_limite    DateTime? @db.Timestamptz()
  valor           Decimal  @default(100) @db.Decimal(5, 2)
  estado          String   @default("borrador")
  publicada_en    DateTime? @db.Timestamptz()
  creada_por      String   @db.Uuid
  metadata        Json     @default("{}")
  created_at      DateTime @default(now()) @db.Timestamptz()
  updated_at      DateTime @updatedAt @db.Timestamptz()


  @@index([materia_id, estado])
}

model actividad_adjuntos {
  id          String   @id @default(uuid()) @db.Uuid
  actividad_id String  @db.Uuid
  nombre      String
  storage_key String
  mime        String?
  tamano_bytes Int?
  created_at  DateTime @default(now()) @db.Timestamptz()

}

model entregas {
  id              String   @id @default(uuid()) @db.Uuid
  institucion_id  String   @db.Uuid
  actividad_id    String   @db.Uuid
  alumno_id       String   @db.Uuid
  version         Int      @default(1)
  estado          String   @default("borrador")
  nota_alumno     String?
  entregada_en    DateTime? @db.Timestamptz()
  created_at      DateTime @default(now()) @db.Timestamptz()
  updated_at      DateTime @updatedAt @db.Timestamptz()


  @@unique([actividad_id, alumno_id])
  @@index([actividad_id, estado])
  @@index([alumno_id])
}

model entrega_archivos {
  id            String   @id @default(uuid()) @db.Uuid
  entrega_id    String   @db.Uuid
  tipo          String
  storage_key   String?
  url_externa   String?
  nombre        String
  mime          String?
  tamano_bytes  Int?
  thumbnail_key String?
  created_at    DateTime @default(now()) @db.Timestamptz()


  @@index([entrega_id])
}

model retroalimentacion {
  id          String   @id @default(uuid()) @db.Uuid
  entrega_id  String   @db.Uuid
  docente_id  String   @db.Uuid
  decision    String
  comentario  String?
  created_at  DateTime @default(now()) @db.Timestamptz()


  @@index([entrega_id, created_at])
}

model calificaciones {
  id              String   @id @default(uuid()) @db.Uuid
  entrega_id      String   @unique @db.Uuid
  actividad_id    String   @db.Uuid
  alumno_id       String   @db.Uuid
  puntaje         Decimal  @db.Decimal(5, 2)
  rubrica         Json?
  calificada_por  String   @db.Uuid
  created_at      DateTime @default(now()) @db.Timestamptz()
  updated_at      DateTime @updatedAt @db.Timestamptz()


  @@index([alumno_id, actividad_id])
}